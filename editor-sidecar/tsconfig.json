{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "../src/editor-ui/*"
      ],
      "app/*": [
        "../src/editor-ui/app/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": false,
    "resolveJsonModule": true,
    "jsx": "preserve"
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.js",
    "./**/*.jsx",
    "./next-env.d.ts",
    "../src/editor-ui/**/*.ts",
    "../src/editor-ui/**/*.tsx",
    "../src/portfolio-os-integration/**/*.js",
    "../src/portfolio-os-integration/**/*.mjs",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
